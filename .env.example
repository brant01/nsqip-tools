# Cross-platform paths: Use /Volumes for portable paths
# Mac: /Volumes → /Volumes
# WSL: /Volumes → /Volumes  
# Linux: /Volumes → /mnt
# Example: DATA_PATH=/Volumes/your_username/data

# NSQIP Tools Environment Configuration Example
# Copy this file to .env and configure with your local paths
# DO NOT commit .env files - they contain local/private information

# Path to your NSQIP data directory
NSQIP_DATA_DIR=/path/to/your/nsqip/data

# Optional: Path to output directory (defaults to data dir)
NSQIP_OUTPUT_DIR=/path/to/output

# Optional: Default memory limit for processing
NSQIP_MEMORY_LIMIT=4GB

# Example paths (uncomment and modify for your setup):
# NSQIP_DATA_DIR=/Volumes/NetworkDrive/NSQIP/2025_Download/data
# NSQIP_DATA_DIR=C:\Data\NSQIP\2025_Download\data
# NSQIP_DATA_DIR=/mnt/shared/nsqip_data